{
  "name": "@claude-mux/muxd",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./bridge": {
      "import": "./dist/bridge/index.js",
      "types": "./dist/bridge/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./daemon": {
      "import": "./dist/daemon/index.js",
      "types": "./dist/daemon/index.d.ts"
    },
    "./runner": {
      "import": "./dist/runner/index.js",
      "types": "./dist/runner/index.d.ts"
    }
  },
  "bin": {
    "muxd": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "cron-parser": "^5.5.0",
    "node-pty": "^1.0.0",
    "strip-ansi": "^7.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
